pipeline {
    agent any // Changed from 'none' to 'any' at the top to keep the same workspace

    parameters {
        string(name: 'ENV', defaultValue: 'dev', description: 'Deployment environment')
    }

    environment {
        APP_NAME = "fullstack-app"
        BUILD_VERSION = "${env.BUILD_NUMBER}"
        // Set PYTHONPATH here so it applies to ALL stages automatically
        PYTHONPATH = "projects/sample_jenkins"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('projects/sample_jenkins') {
                    sh '''
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install -r requirements.txt
                    '''
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('projects/sample_jenkins') {
                    sh '''
                    . venv/bin/activate
                    python3 -m pytest
                    '''
                }
            }
        }

        stage('Parallel Build') {
            parallel {
                stage('Backend Build') {
                    steps {
                        sh "echo 'Building backend version ${env.BUILD_VERSION}...'"
                    }
                }
                stage('Frontend Build') {
                    steps {
                        sh "echo 'Building frontend for ${params.ENV}...'"
                    }
                }
            }
        }

        stage('Package') {
            steps {
                // We go into the project folder so 'zip' can see the backend/frontend folders
                dir('projects/sample_jenkins') {
                    sh 'zip -r app.zip backend frontend'
                }
            }
        }

        stage('Archive') {
            steps {
                // We point to the specific path where the zip was created
                archiveArtifacts artifacts: 'projects/sample_jenkins/app.zip', fingerprint: true
            }
        }

        stage('Use Secret') {
            steps {
                // Ensure you have created a 'Secret Text' credential in Jenkins with ID 'api-key'
                withCredentials([string(credentialsId: 'api-key', variable: 'API_KEY')]) {
                    sh 'echo "Secret loaded successfully. Deployment version: ${BUILD_VERSION}"'
                }
            }
        }

        stage('Conditional Deploy') {
            when {
                expression { params.ENV == 'prod' }
            }
            steps {
                echo "Deploying ${APP_NAME} to production environment..."
            }
        }
    }

    post {
        success {
            echo "Build SUCCESS: ${APP_NAME} v${BUILD_VERSION} is ready."
        }
        failure {
            echo "Build FAILED: Check the console logs for Python or Path errors."
        }
        always {
            echo "Cleaning up temporary files..."
        }
    }
}
