pipeline {
    agent any

    parameters {
        string(name: 'ENV', defaultValue: 'dev', description: 'Deployment environment')
    }

    environment {
        APP_NAME = "sample-jenkins-app"
        // Set the root of the project path for easy reference
        PROJECT_PATH = "projects/sample_jenkins"
        // Ensures Python looks inside the backend folder for imports
        PYTHONPATH = "${env.WORKSPACE}/${env.PROJECT_PATH}"
    }

    stages {
        stage('Initialize') {
            steps {
                dir("${env.PROJECT_PATH}") {
                    echo "Checking environment..."
                    sh '''
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install -r requirements.txt
                    '''
                }
            }
        }

        stage('Run Unit Tests') {
            steps {
                dir("${env.PROJECT_PATH}") {
                    echo "Executing tests in ${env.PROJECT_PATH}/tests"
                    sh '''
                    . venv/bin/activate
                    # Running via 'python3 -m pytest' solves most import errors
                    python3 -m pytest tests/test_app.py
                    '''
                }
            }
        }

        stage('Package Application') {
            steps {
                dir("${env.PROJECT_PATH}") {
                    echo "Zipping frontend and backend folders..."
                    // Zip the specific folders you mentioned
                    sh 'zip -r app.zip backend frontend index.html'
                }
            }
        }

        stage('Archive') {
            steps {
                echo "Archiving artifacts from ${env.PROJECT_PATH}"
                // Path is relative to the Workspace Root
                archiveArtifacts artifacts: "${env.PROJECT_PATH}/app.zip", fingerprint: true
            }
        }

        stage('Deploy (Conditional)') {
            when {
                expression { params.ENV == 'prod' }
            }
            steps {
                echo "Deploying version ${env.BUILD_NUMBER} to production..."
            }
        }
    }

    post {
        success {
            echo "Successfully built and archived: ${env.PROJECT_PATH}/app.zip"
        }
        failure {
            echo "Build failed. Check paths for: ${env.PROJECT_PATH}"
        }
    }
}
