pipeline {
    agent any

    parameters {
        string(name: 'ENV', defaultValue: 'dev', description: 'Deployment environment')
    }

    environment {
        APP_NAME = "harry-microservices"
        // Ensures Python can find your service modules during testing
        PYTHONPATH = "${env.WORKSPACE}"
    }

    stages {
        stage('Initialize & Install') {
            steps {
                echo "Installing dependencies for all services..."
                // Using '.' instead of 'source' for compatibility with Dash shell
                sh '''
                python3 -m venv venv
                . venv/bin/activate
                pip install -r requirements.txt
                '''
            }
        }

        stage('Unit Tests') {
            steps {
                echo "Running centralized tests..."
                sh '''
                . venv/bin/activate
                python3 -m pytest tests/test.py
                '''
            }
        }

        stage('Build User Service') {
            when {
                anyOf {
                    changeset "userService/**"
                    changeset "Jenkinsfile"
                    expression { params.ENV == 'prod' } // Force build if deploying to prod
                }
            }
            steps {
                dir('userService') {
                    echo "Changes detected in User Service. Packaging..."
                    sh 'zip -r userService.zip .'
                }
            }
        }

        stage('Build Chat Service') {
            when {
                anyOf {
                    changeset "chatService/**"
                    changeset "Jenkinsfile"
                }
            }
            steps {
                dir('chatService') {
                    echo "Changes detected in Chat Service. Packaging..."
                    sh 'zip -r chatService.zip .'
                }
            }
        }

        stage('Build Notification Service') {
            when {
                anyOf {
                    changeset "notificationService/**"
                    changeset "Jenkinsfile"
                }
            }
            steps {
                dir('notificationService') {
                    echo "Changes detected in Notification Service. Packaging..."
                    sh 'zip -r notificationService.zip .'
                }
            }
        }

        stage('Archive Artifacts') {
            steps {
                echo "Archiving generated zip files..."
                // This captures all zips from all subfolders
                archiveArtifacts artifacts: '**/*.zip', fingerprint: true, allowEmptyArchive: true
            }
        }
    }

    post {
        success {
            echo "Build Success! Only modified services were processed."
        }
        failure {
            echo "Build Failed. Please check the console output for errors."
        }
        cleanup {
            echo "Cleaning up workspace..."
            // Optional: delete venv or temporary files to save space
        }
    }
}
